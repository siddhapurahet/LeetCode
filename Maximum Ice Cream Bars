class Solution {
public:
    int maxIceCream(vector<int>& costs, int coins) {
        
        sort(costs.begin(), costs.end());
        int max_icecreams = 0;
        
        for(int index : costs) {
            if(index > coins) {
                break;
            } else {
                max_icecreams++;
                coins -= index;
            }
        }
        return max_icecreams;
    }
};

